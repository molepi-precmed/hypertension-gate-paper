	keywords = {Humans, Asian People, Case-Control Studies, Genetic Predisposition to Disease, Genotype, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, Carrier Proteins, Membrane Proteins, Republic of Korea, Autophagy-Related Proteins, HLA-DQ beta-Chains, HLA-DRB1 Chains, OX40 Ligand, Receptors, Purinergic P2Y2, Tumor Necrosis Factor alpha-Induced Protein 3},
	pages = {1197--1209},
	file = {Full Text:/Users/andrico/Documents/Zotero genetics/storage/DF5385N6/Lessard et al. - 2016 - Identification of a Systemic Lupus Erythematosus Risk Locus Spanning ATG16L2, FCHSD2, and P2RY2 in K.pdf:application/pdf},
