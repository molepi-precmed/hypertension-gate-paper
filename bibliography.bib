	urldate = {2024-02-20},
	journal = {Scientific Reports},
	author = {Hasegawa, Hideaki and Mizoguchi, Izuru and Orii, Naoko and Inoue, Shinya and Katahira, Yasuhiro and Yoneto, Toshihiko and Xu, Mingli and Miyazaki, Toru and Yoshimoto, Takayuki},
	month = mar,
