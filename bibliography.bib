@article{nakayasu_plasma_2023,
	title = {Plasma protein biomarkers predict the development of persistent autoantibodies and type 1 diabetes 6 months prior to the onset of autoimmunity},
	volume = {4},
	issn = {26663791},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S2666379123002124},
	doi = {10.1016/j.xcrm.2023.101093},
	abstract = {Type 1 diabetes (T1D) results from autoimmune destruction of b cells. Insufﬁcient availability of biomarkers represents a signiﬁcant gap in understanding the disease cause and progression. We conduct blinded, twophase case-control plasma proteomics on the TEDDY study to identify biomarkers predictive of T1D development. Untargeted proteomics of 2,252 samples from 184 individuals identify 376 regulated proteins, showing alteration of complement, inﬂammatory signaling, and metabolic proteins even prior to autoimmunity onset. Extracellular matrix and antigen presentation proteins are differentially regulated in individuals who progress to T1D vs. those that remain in autoimmunity. Targeted proteomics measurements of 167 proteins in 6,426 samples from 990 individuals validate 83 biomarkers. A machine learning analysis predicts if individuals would remain in autoimmunity or develop T1D 6 months before autoantibody appearance, with areas under receiver operating characteristic curves of 0.871 and 0.918, respectively. Our study identiﬁes and validates biomarkers, highlighting pathways affected during T1D development.},
	language = {en},
	number = {7},
	urldate = {2023-11-28},
