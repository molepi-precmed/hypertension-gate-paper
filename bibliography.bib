	keywords = {aging, cardiovascular disease, heart failure, myocardial infarction, TGR5},
	file = {Full Text PDF:/Users/lana/Zotero/storage/43F269P3/He et al. - 2025 - Takeda G protein–coupled receptor 5 (TGR5) an attractive therapeutic target for aging-related cardi.pdf:application/pdf},
}


