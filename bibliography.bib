	pages = {1578--1582},
	file = {Leffler et al. - 2013 - Multiple Instances of Ancient Balancing Selection .pdf:/Users/lana/Zotero/storage/4GUTB5IV/Leffler et al. - 2013 - Multiple Instances of Ancient Balancing Selection .pdf:application/pdf},
}

@article{mankPopulationGeneticsSexual2017,
