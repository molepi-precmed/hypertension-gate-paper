	file = {Liu et al. - 2017 - Gene-metabolite network analysis in different nona.pdf:/Users/andrico/Documents/Zotero genetics/storage/NS8SAHQB/Liu et al. - 2017 - Gene-metabolite network analysis in different nona.pdf:application/pdf},
}

