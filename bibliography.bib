	keywords = {Gene Expression Regulation, Humans, Animals, Female, Male, Aged, Mice, Hypertension, Inflammation, Angiotensin II, T-Lymphocytes, Lymphocyte Activation, Aldehydes, Antigen-Presenting Cells, B7-1 Antigen, B7-2 Antigen, Cell Proliferation, Cohort Studies, Dendritic Cells, Interleukin-17, Interleukin-1beta, Interleukin-23, Interleukin-6, Kidney, Mice, Transgenic, Middle Aged, Oxidative Stress, Oxygen, Superoxides},
	pages = {4642--4656},
