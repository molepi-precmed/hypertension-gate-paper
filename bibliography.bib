	pmcid = {PMC7858632},
	keywords = {Humans, Genome-Wide Association Study, Asian People, Case-Control Studies, Genetic Heterogeneity, Genetic Predisposition to Disease, Genotype, Linkage Disequilibrium, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, White People},
	pages = {772},
