	file = {science.aaz1776.pdf:/Users/andrico/Documents/Zotero genetics/storage/55ND6MTY/science.aaz1776.pdf:application/pdf},
}

@article{garcia_biochemical_2011,
	title = {Biochemical and genetic analysis of butyrylcholinesterase ({BChE}) in a family, due to prolonged neuromuscular blockade after the use of succinylcholine},
	volume = {34},
	issn = {1415-4757},
	url = {http://www.scielo.br/scielo.php?script=sci_arttext&pid=S1415-47572011000100008&lng=en&tlng=en},
	doi = {10.1590/S1415-47572011000100008},
	abstract = {Butyrylcholinesterase (BChE) is a plasma enzyme that catalyzes the hydrolysis of choline esters, including the muscle-relaxant succinylcholine and mivacurium. Patients who present sustained neuromuscular blockade after using succinylcholine usually carry BChE variants with reduced enzyme activity or an acquired BChE deficiency. We report here the molecular basis of the BCHE gene underlying the slow catabolism of succinylcholine in a patient who underwent endoscopic nasal surgery. We measured the enzyme activity of BChE and extracted genomic DNA in order to study the promoter region and all exons of the BCHE gene of the patient, her parents and siblings. PCR products were sequenced and compared with reference sequences from GenBank. We detected that the patient and one of her brothers have two homozygous mutations: nt1615 GCA {\textgreater} ACA (Ala539Thr), responsible for the K variant, and nt209 GAT {\textgreater} GGT (Asp70Gly), which produces the atypical variant A. Her parents and two of her brothers were found to be heterozygous for the AK allele, and another brother is homozygous for the normal allele. Sequence analysis of exon 1 including 5'UTR showed that the proband and her brother are homozygous for -116GG. The AK/AK genotype is considered the most frequent in hereditary hypocholinesterasemia (44\%). This work demonstrates the importance of defining the phenotype and genotype of the BCHE gene in patients who are subjected to neuromuscular block by succinylcholine, because of the risk of prolonged neuromuscular paralysis.},
	language = {en},
	number = {1},
	urldate = {2022-03-25},
	journal = {Genetics and Molecular Biology},
	author = {Garcia, Daniel Fantozzi and Oliveira, Ticiano G. and Molfetta, Greice A. and Garcia, Luiz V. and Ferreira, Cristiane A. and Marques, Adriana A. and Silva Jr., Wilson Araujo},
	year = {2011},
	pages = {40--44},
	file = {0962280218776989.pdf:/Users/andrico/Documents/Zotero genetics/storage/926GV93U/0962280218776989.pdf:application/pdf;Garcia et al. - 2011 - Biochemical and genetic analysis of butyrylcholine.pdf:/Users/andrico/Documents/Zotero genetics/storage/HUSF6Y64/Garcia et al. - 2011 - Biochemical and genetic analysis of butyrylcholine.pdf:application/pdf},
}

@article{suhre_connecting_2017,
