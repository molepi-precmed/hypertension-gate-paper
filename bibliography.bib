@article{glanville_investigating_2021,
	title = {Investigating {Pleiotropy} {Between} {Depression} and {Autoimmune} {Diseases} {Using} the {UK} {Biobank}},
	volume = {1},
	issn = {26671743},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S2667174321000045},
	doi = {10.1016/j.bpsgos.2021.03.002},
	abstract = {BACKGROUND: Epidemiological studies report increased comorbidity between depression and autoimmune diseases. The role of shared genetic inﬂuences in the observed comorbidity is unclear. We investigated the evidence for pleiotropy between these traits in the UK Biobank (UKB).
	METHODS: We deﬁned autoimmune and depression cases using hospital episode statistics, self-reported conditions and medications, and mental health questionnaires. Pairwise comparisons of depression prevalence between autoimmune cases and controls, and vice versa, were performed. Cross-trait polygenic risk score (PRS) analyses tested for pleiotropy, i.e., whether PRSs for depression could predict autoimmune disease status, and vice versa.
	RESULTS: We identiﬁed 28,479 cases of autoimmune diseases (pooling across 14 traits) and 324,074 autoimmune controls, and 65,075 cases of depression and 232,552 depression controls. The prevalence of depression was signiﬁcantly higher in autoimmune cases than in controls, and similarly, the prevalence of autoimmune disease was higher in depression cases than in controls. PRSs for myasthenia gravis and psoriasis were signiﬁcantly higher in depression cases than in controls (p , 5.2 3 1025, R2 \# 0.04\%). PRSs for depression were signiﬁcantly higher in inﬂammatory bowel disease, psoriasis, psoriatic arthritis, rheumatoid arthritis, and type 1 diabetes cases than in controls (p , 5.8 3 1025, R2 range = 0.06\%–0.27\%), and lower in celiac disease cases than in controls (p , 5.4 3 1027, R2 range = 0.11\%–0.15\%).
	CONCLUSIONS: Consistent with the literature, depression was more common in individuals with autoimmune diseases than in controls, and vice versa. PRSs showed some evidence for involvement of shared genetic factors, but the modest R2 values suggest that shared genetic architecture accounts for a small proportion of the increased risk across traits.},
	language = {en},
	number = {1},
	urldate = {2023-05-08},
	journal = {Biological Psychiatry Global Open Science},
	author = {Glanville, Kylie P. and Coleman, Jonathan R.I. and O'Reilly, Paul F. and Galloway, James and Lewis, Cathryn M.},
	month = jun,
	year = {2021},
	pages = {48--58},
	file = {Glanville et al. - 2021 - Investigating Pleiotropy Between Depression and Au.pdf:/Users/andrico/Documents/Zotero genetics/storage/MCZ7NVIA/Glanville et al. - 2021 - Investigating Pleiotropy Between Depression and Au.pdf:application/pdf},
}

