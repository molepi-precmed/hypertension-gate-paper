@article{thompson_tolllike_2007,
	title = {Toll‐like receptors, {RIG}‐{I}‐like {RNA} helicases and the antiviral innate immune response},
	volume = {85},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
	issn = {0818-9641, 1440-1711},
	url = {https://onlinelibrary.wiley.com/doi/10.1038/sj.icb.7100100},
	doi = {10.1038/sj.icb.7100100},
	abstract = {The antiviral innate immune response follows the detection of viral components by host pattern recognition receptors (PRRs). Two families of PRRs have emerged as key sensors of viral infection: Toll‐like receptors (TLRs) and retinoic acid inducible gene‐I like RNA helicases (RLHs). TLRs patrol the extracellular and endosomal compartments; signalling results in a type‐1 interferon response and/or the production of pro‐inflammatory cytokines. In contrast, RLHs survey the cytoplasm for the presence of viral double‐stranded RNA. In the face of such host defence, viruses have developed strategies to evade TLR/RLH signalling. Such host–virus interactions provide the opportunity for manipulation of PRR signalling as a novel therapeutic approach.},
	language = {en},
	number = {6},
	urldate = {2025-04-17},
	journal = {Immunology \& Cell Biology},
	author = {Thompson, Alex J V and Locarnini, Stephen A},
