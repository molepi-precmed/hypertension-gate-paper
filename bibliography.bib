	pages = {S97--S110},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/DN23F8MH/Murthy et al. - 2023 - The 2023 Impact of Inflammatory Bowel Disease in Canada Treatment Landscape.pdf:application/pdf},
}

@article{mas_selecting_2022,
	title = {Selecting the {Best} {Combined} {Biological} {Therapy} for {Refractory} {Inflammatory} {Bowel} {Disease} {Patients}},
	volume = {11},
	copyright = {https://creativecommons.org/licenses/by/4.0/},
	issn = {2077-0383},
	url = {https://www.mdpi.com/2077-0383/11/4/1076},
	doi = {10.3390/jcm11041076},
	abstract = {Current medical treatment for inﬂammatory bowel disease (IBD) does not achieve 100\% response rates, and a subset of refractory and severely ill patients have persistent active disease after being treated with all possible drug alternatives. The combination of two biological therapies (CoT) seems a reasonable alternative, and has been increasingly tested in very difﬁcult cases. The present review suggests that CoT seems to be safe and effective for refractory and severely ill IBD patients. Ustekinumab plus vedolizumab and vedolizumab plus anti-TNF were the most used CoTs for Crohn’s disease. For ulcerative colitis, the most used CoTs were vedolizumab plus anti-TNF and vedolizumab plus tofacitinib. The aforesaid CoTs have shown good efﬁcacy and few adverse events have been reported.},
	language = {en},
	number = {4},
	urldate = {2025-04-15},
