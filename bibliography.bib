	note = {Publisher: Nature Publishing Group},
	keywords = {Epigenomics, DNA methylation, Cancer epigenetics, Colorectal cancer, Epigenetics},
	pages = {694},
	file = {Full Text PDF:/Users/lana/Zotero/storage/H4EGSX9T/Masalmeh et al. - 2021 - De novo DNA methyltransferase activity in colorect.pdf:application/pdf},
}

