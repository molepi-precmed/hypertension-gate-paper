@article{paek_three_2009,
	title = {{THREE} {STATISTICAL} {TESTING} {PROCEDURES} {IN} {LOGISTIC} {REGRESSION}: {THEIR} {PERFORMANCE} {IN} {DIFFERENTIAL} {ITEM} {FUNCTIONING} ({DIF}) {INVESTIGATION}},
	volume = {2009},
	copyright = {http://onlinelibrary.wiley.com/termsAndConditions\#vor},
	issn = {2330-8516, 2330-8516},
	shorttitle = {{THREE} {STATISTICAL} {TESTING} {PROCEDURES} {IN} {LOGISTIC} {REGRESSION}},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/j.2333-8504.2009.tb02192.x},
	doi = {10.1002/j.2333-8504.2009.tb02192.x},
	abstract = {Three statistical testing procedures well-known in the maximum likelihood approach are the Wald, likelihood ratio (LR), and score tests. Although well-known, the application of these three testing procedures in the logistic regression method to investigate differential item function (DIF) has not been rigorously made yet. Employing a variety of simulation conditions, this research (a) assessed the three tests’ performance for DIF detection and (b) compared DIF detection in different DIF testing modes (targeted vs. general DIF testing). Simulation results showed small differences between the three tests and different testing modes. However, targeted DIF testing consistently performed better than general DIF testing; the three tests differed more in performance in general DIF testing and nonuniform DIF conditions than in targeted DIF testing and uniform DIF conditions; and the LR and score tests consistently performed better than the Wald test.},
	language = {en},
	number = {2},
	urldate = {2024-11-20},
	journal = {ETS Research Report Series},
	author = {Paek, Insu},
	month = dec,
	year = {2009},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/ME6RJINK/Paek - 2009 - THREE STATISTICAL TESTING PROCEDURES IN LOGISTIC REGRESSION THEIR PERFORMANCE IN DIFFERENTIAL ITEM.pdf:application/pdf},
}

@article{zabad_fast_2023,
	title = {Fast and accurate {Bayesian} polygenic risk modeling with variational inference},
	volume = {110},
	issn = {00029297},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0002929723000939},
	doi = {10.1016/j.ajhg.2023.03.009},
	abstract = {The advent of large-scale genome-wide association studies (GWASs) has motivated the development of statistical methods for phenotype prediction with single-nucleotide polymorphism (SNP) array data. These polygenic risk score (PRS) methods use a multiple linear regression framework to infer joint effect sizes of all genetic variants on the trait. Among the subset of PRS methods that operate on GWAS summary statistics, sparse Bayesian methods have shown competitive predictive ability. However, most existing Bayesian approaches employ Markov chain Monte Carlo (MCMC) algorithms, which are computationally inefﬁcient and do not scale favorably to higher dimensions, for posterior inference. Here, we introduce variational inference of polygenic risk scores (VIPRS), a Bayesian summary statistics-based PRS method that utilizes variational inference techniques to approximate the posterior distribution for the effect sizes. Our experiments with 36 simulation conﬁgurations and 12 real phenotypes from the UK Biobank dataset demonstrated that VIPRS is consistently competitive with the state-of-the-art in prediction accuracy while being more than twice as fast as popular MCMC-based approaches. This performance advantage is robust across a variety of genetic architectures, SNP heritabilities, and independent GWAS cohorts. In addition to its competitive accuracy on the ‘‘White British’’ samples, VIPRS showed improved transferability when applied to other ethnic groups, with up to 1.7-fold increase in R2 among individuals of Nigerian ancestry for low-density lipoprotein (LDL) cholesterol. To illustrate its scalability, we applied VIPRS to a dataset of 9.6 million genetic markers, which conferred further improvements in prediction accuracy for highly polygenic traits, such as height.},
	language = {en},
	number = {5},
	urldate = {2024-11-21},
	journal = {The American Journal of Human Genetics},
	author = {Zabad, Shadi and Gravel, Simon and Li, Yue},
	month = may,
	year = {2023},
	pages = {741--761},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/LTLGCMR5/Zabad et al. - 2023 - Fast and accurate Bayesian polygenic risk modeling with variational inference.pdf:application/pdf},
}

@misc{milind_buffering_2024,
	title = {Buffering and non-monotonic behavior of gene dosage response curves for human complex traits},
	copyright = {http://creativecommons.org/licenses/by-nc/4.0/},
	url = {http://medrxiv.org/lookup/doi/10.1101/2024.11.11.24317065},
	doi = {10.1101/2024.11.11.24317065},
	abstract = {A
	bstract
	
	The genome-wide burdens of deletions, loss-of-function mutations, and duplications correlate with many traits. Curiously, for most of these traits, variants that decrease expression have the same genome-wide average direction of effect as variants that increase expression. This seemingly contradicts the intuition that, at individual genes, reducing expression should have the opposite effect on a phenotype as increasing expression. To understand this paradox, we introduce a concept called the gene dosage response curve (GDRC) that relates changes in gene expression to expected changes in phenotype. We show that, for many traits, GDRCs are systematically biased in one trait direction relative to the other and, surprisingly, that as many as 40\% of GDRCs are non-monotone, with large increases and decreases in expression affecting the trait in the same direction. We develop a simple theoretical model that explains this bias in trait direction. Our results have broad implications for complex traits, drug discovery, and statistical genetics.},
	language = {en},
	urldate = {2024-11-29},
	publisher = {Genetic and Genomic Medicine},
	author = {Milind, Nikhil and Smith, Courtney J. and Zhu, Huisheng and Spence, Jeffrey P. and Pritchard, Jonathan K.},
	month = nov,
	year = {2024},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/XISS6SU3/Milind et al. - 2024 - Buffering and non-monotonic behavior of gene dosage response curves for human complex traits.pdf:application/pdf},
}

