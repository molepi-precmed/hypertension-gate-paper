	file = {Szklarczyk et al. - 2015 - STRING v10 protein–protein interaction networks, .pdf:/Users/andrico/Documents/Zotero genetics/storage/8N4GUL7F/Szklarczyk et al. - 2015 - STRING v10 protein–protein interaction networks, .pdf:application/pdf},
