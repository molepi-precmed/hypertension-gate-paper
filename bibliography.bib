@article{golkaramMacromolecularCrowdingRegulates2016,
	title = {Macromolecular {Crowding} {Regulates} the {Gene} {Expression} {Profile} by {Limiting} {Diffusion}},
	volume = {12},
	issn = {1553-7358},
	url = {https://journals.plos.org/ploscompbiol/article?id=10.1371/journal.pcbi.1005122},
	doi = {10.1371/journal.pcbi.1005122},
	abstract = {We seek to elucidate the role of macromolecular crowding in transcription and translation. It is well known that stochasticity in gene expression can lead to differential gene expression and heterogeneity in a cell population. Recent experimental observations by Tan et al. have improved our understanding of the functional role of macromolecular crowding. It can be inferred from their observations that macromolecular crowding can lead to robustness in gene expression, resulting in a more homogeneous cell population. We introduce a spatial stochastic model to provide insight into this process. Our results show that macromolecular crowding reduces noise (as measured by the kurtosis of the mRNA distribution) in a cell population by limiting the diffusion of transcription factors (i.e. removing the unstable intermediate states), and that crowding by large molecules reduces noise more efficiently than crowding by small molecules. Finally, our simulation results provide evidence that the local variation in chromatin density as well as the total volume exclusion of the chromatin in the nucleus can induce a homogenous cell population.},
	language = {en},
	number = {11},
	urldate = {2020-03-11},
	journal = {PLOS Computational Biology},
	author = {Golkaram, Mahdi and Hellander, Stefan and Drawert, Brian and Petzold, Linda R.},
	month = nov,
	year = {2016},
	keywords = {Agent-based modeling, Biochemical simulations, Chromatin, DNA transcription, Gene expression, Mass diffusivity, Simulation and modeling, Transcription factors},
	pages = {e1005122},
	file = {Full Text PDF:/Users/lana/Zotero/storage/5534RB28/Golkaram et al. - 2016 - Macromolecular Crowding Regulates the Gene Express.pdf:application/pdf;Snapshot:/Users/lana/Zotero/storage/56EENKHS/journal.pcbi.html:text/html},
}

@article{tabakaEffectMacromolecularCrowding2014,
	title = {The effect of macromolecular crowding on mobility of biomolecules, association kinetics, and gene expression in living cells},
	volume = {2},
	issn = {2296-424X},
	url = {https://www.frontiersin.org/articles/10.3389/fphy.2014.00054/full},
	doi = {10.3389/fphy.2014.00054},
	abstract = {We discuss a quantitative influence of macromolecular crowding on biological processes: motion, bimolecular reactions, and gene expression in prokaryotic and eukaryotic cells. We present scaling laws relating diffusion coefficient of an object moving in a cytoplasm of cells to a size of this object and degree of crowding. Such description leads to the notion of the length scale dependent viscosity characteristic for all living cells. We present an application of the length-scale dependent viscosity model to the description of motion in the cytoplasm of both eukaryotic and prokaryotic living cells. We compare the model with all recent data on diffusion of nanoscopic objects in HeLa, and E. coli cells. Additionally a description of the mobility of molecules in cell nucleus is presented. Finally we discuss the influence of crowding on the bimolecular association rates and gene expression in living cells.},
	language = {English},
	urldate = {2020-03-11},
	journal = {Frontiers in Physics},
	author = {Tabaka, Marcin and Kalwarczyk, Tomasz and Szymanski, Jedrzej and Hou, Sen and Holyst, Robert},
	year = {2014},
	keywords = {biologistics, biomolecules diffusion, Gene Expression, kinetics of biomolecules in vivo, Macromolecular crowding},
	file = {Full Text PDF:/Users/lana/Zotero/storage/TKM952Q9/Tabaka et al. - 2014 - The effect of macromolecular crowding on mobility .pdf:application/pdf},
}

