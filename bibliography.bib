	pages = {22690--22709},
	file = {Full Text PDF:/Users/lana/Zotero/storage/9QYWTRFI/Castelblanco et al. - 2021 - Circulating CD5L is associated with cardiovascular events and all-cause mortality in individuals wit.pdf:application/pdf},
