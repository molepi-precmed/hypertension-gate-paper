	pages = {470--481},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/W3CEX3MK/Elias et al. - 2019 - EMSY expression affects multiple components of the skin barrier with relevance to atopic dermatitis.pdf:application/pdf},
}

