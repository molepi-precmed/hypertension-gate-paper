@article{khoramipour_adiponectin_2021,
	title = {Adiponectin: {Structure}, {Physiological} {Functions}, {Role} in {Diseases}, and {Effects} of {Nutrition}},
	volume = {13},
	copyright = {https://creativecommons.org/licenses/by/4.0/},
	issn = {2072-6643},
	shorttitle = {Adiponectin},
	url = {https://www.mdpi.com/2072-6643/13/4/1180},
	doi = {10.3390/nu13041180},
	abstract = {Adiponectin (a protein consisting of 244 amino acids and characterized by a molecular weight of 28 kDa) is a cytokine that is secreted from adipose tissues (adipokine). Available evidence suggests that adiponectin is involved in a variety of physiological functions, molecular and cellular events, including lipid metabolism, energy regulation, immune response and inﬂammation, and insulin sensitivity. It has a protective effect on neurons and neural stem cells. Adiponectin levels have been reported to be negatively correlated with cancer, cardiovascular disease, and diabetes, and shown to be affected (i.e., signiﬁcantly increased) by proper healthy nutrition. The present review comprehensively overviews the role of adiponectin in a range of diseases, showing that it can be used as a biomarker for diagnosing these disorders as well as a target for monitoring the effectiveness of preventive and treatment interventions.},
	language = {en},
	number = {4},
	urldate = {2024-07-24},
	journal = {Nutrients},
	author = {Khoramipour, Kayvan and Chamari, Karim and Hekmatikar, Amirhosein Ahmadi and Ziyaiyan, Amirhosein and Taherkhani, Shima and Elguindy, Nihal M. and Bragazzi, Nicola Luigi},
