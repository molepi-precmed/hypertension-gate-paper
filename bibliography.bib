@article{rivellese_rituximab_2022,
	title = {Rituximab versus tocilizumab in rheumatoid arthritis: synovial biopsy-based biomarker analysis of the phase 4 {R4RA} randomized trial},
	volume = {28},
	issn = {1078-8956, 1546-170X},
	shorttitle = {Rituximab versus tocilizumab in rheumatoid arthritis},
	url = {https://www.nature.com/articles/s41591-022-01789-0},
	doi = {10.1038/s41591-022-01789-0},
	abstract = {Abstract
	
	Patients with rheumatoid arthritis (RA) receive highly targeted biologic therapies without previous knowledge of target expression levels in the diseased tissue. Approximately 40\% of patients do not respond to individual biologic therapies and 5–20\% are refractory to all. In a biopsy-based, precision-medicine, randomized clinical trial in RA (R4RA;
	n
	= 164), patients with low/absent synovial B cell molecular signature had a lower response to rituximab (anti-CD20 monoclonal antibody) compared with that to tocilizumab (anti-IL6R monoclonal antibody) although the exact mechanisms of response/nonresponse remain to be established. Here, in-depth histological/molecular analyses of R4RA synovial biopsies identify humoral immune response gene signatures associated with response to rituximab and tocilizumab, and a stromal/fibroblast signature in patients refractory to all medications. Post-treatment changes in synovial gene expression and cell infiltration highlighted divergent effects of rituximab and tocilizumab relating to differing response/nonresponse mechanisms. Using ten-by-tenfold nested cross-validation, we developed machine learning algorithms predictive of response to rituximab (area under the curve (AUC) = 0.74), tocilizumab (AUC = 0.68) and, notably, multidrug resistance (AUC = 0.69). This study supports the notion that disease endotypes, driven by diverse molecular pathology pathways in the diseased tissue, determine diverse clinical and treatment–response phenotypes. It also highlights the importance of integration of molecular pathology signatures into clinical algorithms to optimize the future use of existing medications and inform the development of new drugs for refractory patients.},
	language = {en},
	number = {6},
	urldate = {2024-05-17},
	journal = {Nature Medicine},
	author = {Rivellese, Felice and Surace, Anna E. A. and Goldmann, Katriona and Sciacca, Elisabetta and Çubuk, Cankut and Giorli, Giovanni and John, Christopher R. and Nerviani, Alessandra and Fossati-Jimack, Liliane and Thorborn, Georgina and Ahmed, Manzoor and Prediletto, Edoardo and Church, Sarah E. and Hudson, Briana M. and Warren, Sarah E. and McKeigue, Paul M. and Humby, Frances and Bombardieri, Michele and Barnes, Michael R. and Lewis, Myles J. and Pitzalis, Costantino and {the R4RA collaborative group} and Rivellese, Felice and Giorli, Giovanni and Nerviani, Alessandra and Fossati-Jimack, Liliane and Thorborn, Georgina and Humby, Frances and Bombardieri, Michele and Lewis, Myles J. and Durez, Patrick and Buch, Maya H. and Rizvi, Hasan and Mahto, Arti and Montecucco, Carlomaurizio and Lauwerys, Bernard and Ng, Nora and Ho, Pauline and Romão, Vasco C. and Da Fonseca, João Eurico Cabral and Verschueren, Patrick and Kelly, Stephen and Sainaghi, Pier Paolo and Gendi, Nagui and Dasgupta, Bhaskar and Cauli, Alberto and Reynolds, Piero and Cañete, Juan D. and Ramirez, Julio and Celis, Raquel and Moots, Robert and Taylor, Peter C. and Edwards, Chris J. and Isaacs, John and Sasieni, Peter and Choy, Ernest and Thompson, Charlotte and Bugatti, Serena and Bellan, Mattia and Congia, Mattia and Holroyd, Christopher and Pratt, Arthur and White, Laura and Warren, Louise and Peel, Joanna and Hands, Rebecca and Hadfield, Gaye and Pitzalis, Costantino},
	month = jun,
