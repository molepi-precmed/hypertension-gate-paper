@article{goldmann_expression_2023,
	title = {Expression {Quantitative} {Trait} {Loci} {Analysis} in {Rheumatoid} {Arthritis} {Identifies} {Tissue} {Specific} {Variants} {Associated} with {Severity} and {Outcome}},
	abstract = {Genome-wide association studies have successfully identified more than 100 loci associated with susceptibility to rheumatoid arthritis (RA). However, our understanding of the functional effects of genetic variants in causing RA and their effects on disease severity and response to treatment remains limited. In this study we conducted expression quantitative trait locus (eQTL) analysis to dissect the link between genetic variants and gene expression comparing the disease tissue against blood using RNA-Sequencing of synovial biopsies (n=85) and blood samples (n=51) from treatment-naïve rheumatoid arthritis patients from the Pathobiology of Early Arthritis Cohort (PEAC). This identified 898 loci in synovium and 1251 loci in blood, with 232 genes in common to both synovium and blood. Notably many eQTL were tissue specific, highlighting the need to explore functional consequences of genetic associations in disease tissue. Examining the HLA region, we uncovered a specific eQTL at HLA-DPB2 with the critical triad of SNPs driving synovial gene expression, and both SNPs and gene expression correlating with clinical severity, suggesting an eQTL of clinical relevance in RA pathogenesis.},
	journal = {Annals of the Rheumatic Diseases},
	author = {Goldmann, Katriona and Spiliopoulou, Athina and Iakovliev, Andrii and Plant, Darren and Nair, Nisha and The Matura Consortium and McKeigue, Paul and Barnes, Michael R and Barton, Anne and Pitzalis, Costantino and Lewis, Myles J},
	month = mar,
	year = {2023},
	file = {Goldmann et al. - 2023 - Expression quantitative trait loci analysis in rhe.pdf:/Users/andrico/Documents/Zotero genetics/storage/S6NBWBPU/Goldmann et al. - 2023 - Expression quantitative trait loci analysis in rhe.pdf:application/pdf;Goldmann_manuscript.pdf:/Users/andrico/Documents/Zotero genetics/storage/23MUZYU5/Goldmann_manuscript.pdf:application/pdf},
}

