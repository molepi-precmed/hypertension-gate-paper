	file = {Berry et al. - 2021 - Nuclear RNA concentration coordinates RNA producti.pdf:/Users/lana/Zotero/storage/XEZD9NII/Berry et al. - 2021 - Nuclear RNA concentration coordinates RNA producti.pdf:application/pdf},
}

@article{sunGlobalAnalysisEukaryotic2013,
	title = {Global {Analysis} of {Eukaryotic} {mRNA} {Degradation} {Reveals} {Xrn1}-{Dependent} {Buffering} of {Transcript} {Levels}},
