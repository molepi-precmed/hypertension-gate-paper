	keywords = {Humans, Genome-Wide Association Study, Genetic Predisposition to Disease, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, Risk Factors, Co-Repressor Proteins, DNA Replication, DNA-Binding Proteins, Interleukin-10, Neoplasm Proteins, Positive Regulatory Domain I-Binding Factor 1, Repressor Proteins},
