	title = {A novel human monogenic obesity trait: severe early-onset childhood obesity caused by aberrant expression of agouti-signaling protein ({ASIP}): a case report},
	copyright = {https://creativecommons.org/licenses/by/4.0/},
	shorttitle = {A novel human monogenic obesity trait},
	url = {https://www.researchsquare.com/article/rs-1459517/v1},
