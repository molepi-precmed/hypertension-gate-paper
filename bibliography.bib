@article{miuraPhylogeneticApproachStudy2022,
	title = {A phylogenetic approach to study the evolution of somatic mutational processes in cancer},
	volume = {5},
	copyright = {2022 The Author(s)},
	issn = {2399-3642},
	url = {https://www.nature.com/articles/s42003-022-03560-0},
	doi = {10.1038/s42003-022-03560-0},
	abstract = {Cancer cell genomes change continuously due to mutations, and mutational processes change over time in patients, leaving dynamic signatures in the accumulated genomic variation in tumors. Many computational methods detect the relative activities of known mutation signatures. However, these methods may produce erroneous signatures when applied to individual branches in cancer cell phylogenies. Here, we show that the inference of branch-specific mutational signatures can be improved through a joint analysis of the collections of mutations mapped on proximal branches of the cancer cell phylogeny. This approach reduces the false-positive discovery rate of branch-specific signatures and can sometimes detect faint signatures. An analysis of empirical data from 61 lung cancer patients supports trends based on computer-simulated datasets for which the correct signatures are known. In lung cancer somatic variation, we detect a decreasing trend of smoking-related mutational processes over time and an increasing influence of APOBEC mutational processes as the tumor evolution progresses. These analyses also reveal patterns of conservation and divergence of mutational processes in cell lineages within patients.},
	language = {en},
	number = {1},
	urldate = {2024-05-02},
	journal = {Communications Biology},
	author = {Miura, Sayaka and Vu, Tracy and Choi, Jiyeong and Townsend, Jeffrey P. and Karim, Sajjad and Kumar, Sudhir},
	month = jun,
	year = {2022},
	note = {Publisher: Nature Publishing Group},
	keywords = {Molecular evolution, Statistical methods, Tumour heterogeneity},
	pages = {1--11},
	file = {Full Text PDF:/Users/lana/Zotero/storage/DGXICDTF/Miura et al. - 2022 - A phylogenetic approach to study the evolution of .pdf:application/pdf},
}

@misc{ewingDivergentTrajectoriesStructural2024,
	title = {Divergent trajectories to structural diversity impact patient survival in high grade serous ovarian cancer},
	url = {http://biorxiv.org/lookup/doi/10.1101/2024.01.12.575376},
	doi = {10.1101/2024.01.12.575376},
	abstract = {Deciphering the structural variation across tumour genomes is crucial to determine the events driving tumour progression and better understand tumour adaptation and evolution. High grade serous ovarian cancer (HGSOC) is an exemplar tumour type showing extreme, but poorly characterised structural diversity. We comprehensively describe the mutational landscape driving HGSOC, exploiting a large (N=324), deeply whole genome sequenced dataset. We reveal two divergent evolutionary trajectories, affecting patient survival and involving differing genomic environments. One involves homologous recombination repair deficiency (HRD) while the other is dominated by whole genome duplication (WGD) with frequent chromothripsis, breakage-fusion-bridges and extra-chromosomal DNA. These trajectories contribute to structural variation hotspots, containing novel candidate driver genes with significantly altered expression. While structural variation predominantly drives tumorigenesis, we also find high mtDNA mutation loads associated with shorter patient survival, and acting in combination with alterations in the nuclear genome to impact prognosis and suggesting new strategies for patient stratification.},
	language = {en},
	urldate = {2024-05-10},
	author = {Ewing, Ailith and Meynert, Alison and Silk, Ryan and Aitken, Stuart and Bendixsen, Devin P. and Churchman, Michael and Brown, Stuart L. and Hamdan, Alhafidz and Mattocks, Joanne and Grimes, Graeme R. and Ballinger, Tracy and Hollis, Robert L. and Herrington, C. Simon and Thomson, John P. and Sherwood, Kitty and Parry, Thomas and Esiri-Bloom, Edward and Bartos, Clare and Croy, Ian and Ferguson, Michelle and Lennie, Mairi and McGoldrick, Trevor and McPhail, Neil and Siddiqui, Nadeem and Glasspool, Rosalind and Mackean, Melanie and Nussey, Fiona and McDade, Brian and Ennis, Darren and {The Scottish Genomes Partnership} and McMahon, Lynn and Matakidou, Athena and Dougherty, Brian and March, Ruth and Barrett, J. Carl and McNeish, Iain A. and Biankin, Andrew V. and Roxburgh, Patricia and Gourley, Charlie and Semple, Colin A.},
	month = jan,
	year = {2024},
	file = {Ewing et al. - 2024 - Divergent trajectories to structural diversity imp.pdf:/Users/lana/Zotero/storage/XBCRLQCX/Ewing et al. - 2024 - Divergent trajectories to structural diversity imp.pdf:application/pdf},
}

@article{gillyCohortwideDeepWhole2018,
	title = {Cohort-wide deep whole genome sequencing and the allelic architecture of complex traits},
