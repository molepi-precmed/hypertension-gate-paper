@article{huanMetaanalysisGeneExpression2015,
	title = {A {Meta}-analysis of {Gene} {Expression} {Signatures} of {Blood} {Pressure} and {Hypertension}},
	volume = {11},
	issn = {1553-7404},
	url = {https://journals.plos.org/plosgenetics/article?id=10.1371/journal.pgen.1005035},
	doi = {10.1371/journal.pgen.1005035},
	abstract = {Genome-wide association studies (GWAS) have uncovered numerous genetic variants (SNPs) that are associated with blood pressure (BP). Genetic variants may lead to BP changes by acting on intermediate molecular phenotypes such as coded protein sequence or gene expression, which in turn affect BP variability. Therefore, characterizing genes whose expression is associated with BP may reveal cellular processes involved in BP regulation and uncover how transcripts mediate genetic and environmental effects on BP variability. A meta-analysis of results from six studies of global gene expression profiles of BP and hypertension in whole blood was performed in 7017 individuals who were not receiving antihypertensive drug treatment. We identified 34 genes that were differentially expressed in relation to BP (Bonferroni-corrected p{\textless}0.05). Among these genes, FOS and PTGS2 have been previously reported to be involved in BP-related processes; the others are novel. The top BP signature genes in aggregate explain 5\%–9\% of inter-individual variance in BP. Of note, rs3184504 in SH2B3, which was also reported in GWAS to be associated with BP, was found to be a trans regulator of the expression of 6 of the transcripts we found to be associated with BP (FOS, MYADM, PP1R15A, TAGAP, S100A10, and FGBP2). Gene set enrichment analysis suggested that the BP-related global gene expression changes include genes involved in inflammatory response and apoptosis pathways. Our study provides new insights into molecular mechanisms underlying BP regulation, and suggests novel transcriptomic markers for the treatment and prevention of hypertension.},
	language = {en},
	number = {3},
	urldate = {2025-11-11},
	journal = {PLOS Genetics},
	author = {Huan, Tianxiao and Esko, Tõnu and Peters, Marjolein J. and Pilling, Luke C. and Schramm, Katharina and Schurmann, Claudia and Chen, Brian H. and Liu, Chunyu and Joehanes, Roby and Johnson, Andrew D. and Yao, Chen and Ying, Sai-xia and Courchesne, Paul and Milani, Lili and Raghavachari, Nalini and Wang, Richard and Liu, Poching and Reinmaa, Eva and Dehghan, Abbas and Hofman, Albert and Uitterlinden, André G. and Hernandez, Dena G. and Bandinelli, Stefania and Singleton, Andrew and Melzer, David and Metspalu, Andres and Carstensen, Maren and Grallert, Harald and Herder, Christian and Meitinger, Thomas and Peters, Annette and Roden, Michael and Waldenberger, Melanie and Dörr, Marcus and Felix, Stephan B. and Zeller, Tanja and Gwas (icbp), International Consortium for Blood Pressure and Vasan, Ramachandran and O'Donnell, Christopher J. and Munson, Peter J. and Yang, Xia and Prokisch, Holger and Völker, Uwe and Meurs, Joyce B. J. van and Ferrucci, Luigi and Levy, Daniel},
	month = mar,
	year = {2015},
	note = {Publisher: Public Library of Science},
	keywords = {Cardiology, Clinical genetics, Drug research and development, Gene expression, Genetic epidemiology, Genome-wide association studies, Medicine and health sciences, Pulmonology},
	pages = {e1005035},
