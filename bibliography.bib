@article{dudbridge_polygenic_2016,
	title = {Polygenic {Epidemiology}},
	volume = {40},
	issn = {0741-0395, 1098-2272},
	url = {https://onlinelibrary.wiley.com/doi/10.1002/gepi.21966},
	doi = {10.1002/gepi.21966},
	abstract = {Much of the genetic basis of complex traits is present on current genotyping products, but the individual variants that affect the traits have largely not been identiﬁed. Several traditional problems in genetic epidemiology have recently been addressed by assuming a polygenic basis for disease and treating it as a single entity. Here I brieﬂy review some of these applications, which collectively may be termed polygenic epidemiology. Methodologies in this area include polygenic scoring, linear mixed models, and linkage disequilibrium scoring. They have been used to establish a polygenic effect, estimate genetic correlation between traits, estimate how many variants affect a trait, stratify cases into subphenotypes, predict individual disease risks, and infer causal effects using Mendelian randomization. Polygenic epidemiology will continue to yield useful applications even while much of the speciﬁc variation underlying complex traits remains undiscovered.},
	language = {en},
	number = {4},
	urldate = {2021-09-22},
	journal = {Genetic Epidemiology},
	author = {Dudbridge, Frank},
	month = may,
	year = {2016},
	pages = {268--272},
	file = {Dudbridge - 2016 - Polygenic Epidemiology.pdf:/Users/andrico/Documents/Zotero genetics/storage/F777SMVD/Dudbridge - 2016 - Polygenic Epidemiology.pdf:application/pdf},
}

