@article{liRegulatoryCellsProtect2023,
	title = {Regulatory {B} cells protect against chronic hypoxia-induced pulmonary hypertension by modulating the {Tfh}/{Tfr} immune balance},
	volume = {168},
	copyright = {© 2022 John Wiley \& Sons Ltd.},
