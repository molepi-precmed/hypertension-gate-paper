@article{palmeriExploitingHolisticApproaches2014,
	title = {Exploiting holistic approaches to model specificity in protein phosphorylation},
	volume = {5},
	issn = {1664-8021},
	url = {https://www.frontiersin.org/articles/10.3389/fgene.2014.00315/full},
	doi = {10.3389/fgene.2014.00315},
	abstract = {Phosphate plays a chemically unique role in shaping cellular signaling of all current living systems, especially eukaryotes. Protein phosphorylation has been studied at several levels, from the near-site context, both in sequence and structure, to the crowded cellular environment, and ultimately to the systems-level perspective. Despite the tremendous advances in mass spectrometry and efforts dedicated to the development of ad hoc highly sophisticated methods, phosphorylation site inference and associated kinase identification are still unresolved problems in kinome biology. The sequence and structure of the substrate near-site context are not sufficient alone to model the in vivo phosphorylation rules, and they should be integrated with orthogonal information in all possible applications. Here we provide an overview of the different contexts that contribute to protein phosphorylation, discussing their potential impact in phosphorylation site annotation and in predicting kinase-substrate specificity.},
	language = {English},
