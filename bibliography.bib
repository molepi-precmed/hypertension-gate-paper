	pages = {e8746},
	file = {Full Text:/Users/lana/Zotero/storage/PI6EKYUG/Luecken and Theis - 2019 - Current best practices in single‐cell RNA‐seq anal.pdf:application/pdf},
}

@article{gilTcellDysfunctionSymptoms2024,
	title = {T-cell dysfunction and symptoms of {ME}/{CFS} and {Long} {COVID} improve on {Inspiritol} {Treatment}},
	volume = {212},
	issn = {0022-1767},
	url = {https://doi.org/10.4049/jimmunol.212.supp.0147.5633},
	doi = {10.4049/jimmunol.212.supp.0147.5633},
	abstract = {Patients with post-acute sequelae of SARS-CoV-2 infection (i.e., Long COVID), the new pandemic, have a symptom complex highly analogous to ME/CFS, suggesting that at least a subset may have the same disorder. The immunopathogenesis of both disorders is still poorly understood. Here, we hypothesize that Long COVID and ME/CFS maybe due to an aberrant response to an immunological trigger like infection, which results in a dysregulated immune system.  We have identified a potential with open-label treatment, Inspiritol that can relieve oxidative stress, attenuate NF-κB signaling, and act directly against pathogens. We conducted an analysis of CD8 T cell function in ME/CFS (n=12), Long COVID (n=8) and healthy age- and sex-matched controls (n=10) and examined changes in these immune parameters and in self-reported symptoms. The developed CD8 T cell functional assay (cytokine production) and questionnaire were used to track disease outcome during therapy.  Here we present two observations fundamental to the pathogenesis and treatment of Long COVID and ME/CFS: 1) both diseases are characterized by exhausted T cells with severe deficiencies in their abilities to produce IFNg and TNFa; 2) a new immune-modulatory and anti-oxidant reagent corrects this immune deficiency and improves health of the patients. This work provides evidence of a new treatment and a biomarker useful for diagnosis and tracking of treatment outcomes that can help expedite clinical trials in  Long COVID and ME/CFS.},
	number = {1\_Supplement},
	urldate = {2024-12-10},
	journal = {The Journal of Immunology},
	author = {Gil, Anna and Hoag, George and Salerno, John and Hornig, Mady and Klimas, Nancy and Selin, Liisa},
	month = may,
	year = {2024},
	pages = {0147\_5633},
	file = {Full Text PDF:/Users/lana/Zotero/storage/QSAZ3TJ8/Gil et al. - 2024 - T-cell dysfunction and symptoms of MECFS and Long.pdf:application/pdf;Snapshot:/Users/lana/Zotero/storage/DIZCNXRB/268055.html:text/html},
}

@article{hodgsonGeneticBasisEarly2024,
	title = {Genetic basis of early onset and progression of type 2 diabetes in {South} {Asians}},
	copyright = {2024 The Author(s)},
	issn = {1546-170X},
	url = {https://www.nature.com/articles/s41591-024-03317-8},
	doi = {10.1038/s41591-024-03317-8},
	abstract = {South Asians develop type 2 diabetes (T2D) early in life and often with normal body mass index (BMI). However, reasons for this are poorly understood because genetic research is largely focused on European ancestry groups. We used recently derived multi-ancestry partitioned polygenic scores (pPSs) to elucidate underlying etiological pathways British Pakistani and British Bangladeshi individuals with T2D (n = 11,678) and gestational diabetes mellitus (GDM) (n = 1,965) in the Genes \& Health study (n = 50,556). Beta cell 2 (insulin deficiency) and Lipodystrophy 1 (unfavorable fat distribution) pPSs were most strongly associated with T2D, GDM and younger age at T2D diagnosis. Individuals at high genetic risk of both insulin deficiency and lipodystrophy were diagnosed with T2D 8.2 years earlier with BMI 3 kg m−2 lower compared to those at low genetic risk. The insulin deficiency pPS was associated with poorer HbA1c response to SGLT2 inhibitors. Insulin deficiency and lipodystrophy pPSs were associated with faster progression to insulin dependence and microvascular complications. South Asians had a greater genetic burden from both of these pPSs than white Europeans in the UK Biobank. In conclusion, genetic predisposition to insulin deficiency and lipodystrophy in British Pakistani and British Bangladeshi individuals is associated with earlier onset of T2D, faster progression to complications, insulin dependence and poorer response to medication.},
	language = {en},
	urldate = {2024-12-10},
	journal = {Nature Medicine},
	author = {Hodgson, Sam and Williamson, Alice and Bigossi, Margherita and Stow, Daniel and Jacobs, Benjamin M. and Samuel, Miriam and Gafton, Joseph and Zöllner, Julia and Spreckley, Marie and Langenberg, Claudia and van Heel, David A. and Mathur, Rohini and Siddiqui, Moneeza K. and Finer, Sarah},
	month = nov,
	year = {2024},
	note = {Publisher: Nature Publishing Group},
	keywords = {Type 2 diabetes, Disease genetics, Genetics research},
	pages = {1--9},
	file = {Full Text PDF:/Users/lana/Zotero/storage/L3UUP4QD/Hodgson et al. - 2024 - Genetic basis of early onset and progression of ty.pdf:application/pdf},
}

@article{kilanowskaRolePhosphodiesteraseBiology2020,
	title = {Role of {Phosphodiesterase} in the {Biology} and {Pathology} of {Diabetes}},
	volume = {21},
	issn = {1422-0067},
	url = {https://www.ncbi.nlm.nih.gov/pmc/articles/PMC7662747/},
	doi = {10.3390/ijms21218244},
	abstract = {Glucose metabolism is the initiator of a large number of molecular secretory processes in β cells. Cyclic nucleotides as a second messenger are the main physiological regulators of these processes and are functionally divided into compartments in pancreatic cells. Their intracellular concentration is limited by hydrolysis led by one or more phosphodiesterase (PDE) isoenzymes. Literature data confirmed multiple expressions of PDEs subtypes, but the specific roles of each in pancreatic β-cell function, particularly in humans, are still unclear. Isoforms present in the pancreas are also found in various tissues of the body. Normoglycemia and its strict control are supported by the appropriate release of insulin from the pancreas and the action of insulin in peripheral tissues, including processes related to homeostasis, the regulation of which is based on the PDE- cyclic AMP (cAMP) signaling pathway. The challenge in developing a therapeutic solution based on GSIS (glucose-stimulated insulin secretion) enhancers targeted at PDEs is the selective inhibition of their activity only within β cells. Undeniably, PDEs inhibitors have therapeutic potential, but some of them are burdened with certain adverse effects. Therefore, the chance to use knowledge in this field for diabetes treatment has been postulated for a long time.},
	number = {21},
	urldate = {2024-12-10},
	journal = {International Journal of Molecular Sciences},
	author = {Kilanowska, Agnieszka and Ziółkowska, Agnieszka},
	month = nov,
	year = {2020},
	pmid = {33153226},
	pmcid = {PMC7662747},
	pages = {8244},
	file = {PubMed Central Full Text PDF:/Users/lana/Zotero/storage/KEFCNPXF/Kilanowska and Ziółkowska - 2020 - Role of Phosphodiesterase in the Biology and Patho.pdf:application/pdf},
}

@article{luntIntroductionStatisticalModelling2015,
	title = {Introduction to statistical modelling 2: categorical variables and interactions in linear regression},
	volume = {54},
	issn = {1462-0324},
	shorttitle = {Introduction to statistical modelling 2},
	url = {https://doi.org/10.1093/rheumatology/ket172},
	doi = {10.1093/rheumatology/ket172},
	abstract = {In the first article in this series we explored the use of linear regression to predict an outcome variable from a number of predictive factors. It assumed that the predictive factors were measured on an interval scale. However, this article shows how categorical variables can also be included in a linear regression model, enabling predictions to be made separately for different groups and allowing for testing the hypothesis that the outcome differs between groups. The use of interaction terms to measure whether the effect of a particular predictor variable differs between groups is also explained. An alternative approach to testing the difference between groups of the effect of a given predictor, which consists of measuring the effect in each group separately and seeing whether the statistical significance differs between the groups, is shown to be misleading.},
