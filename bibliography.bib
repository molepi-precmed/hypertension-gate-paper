	file = {Uffelmann et al. - 2021 - Genome-wide association studies.pdf:/Users/andrico/Documents/Zotero genetics/storage/H5GX4ZHT/Uffelmann et al. - 2021 - Genome-wide association studies.pdf:application/pdf},
}

