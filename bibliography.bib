@article{bingley_type_2018,
	title = {Type 1 {Diabetes} {TrialNet}: {A} {Multifaceted} {Approach} to {Bringing} {Disease}-{Modifying} {Therapy} to {Clinical} {Use} in {Type} 1 {Diabetes}},
	volume = {41},
	issn = {0149-5992, 1935-5548},
	shorttitle = {Type 1 {Diabetes} {TrialNet}},
	url = {https://diabetesjournals.org/care/article/41/4/653/36875/Type-1-Diabetes-TrialNet-A-Multifaceted-Approach},
	doi = {10.2337/dc17-0806},
	abstract = {What will it take to bring disease-modifying therapy to clinical use in type 1 diabetes? Coordinated efforts of investigators involved in discovery, translational, and clinical research operating in partnership with funders and industry and in sync with regulatory agencies are needed. This Perspective describes one such effort, Type 1 Diabetes TrialNet, a National Institutes of Health–funded and JDRF-supported international clinical trials network that emerged from the Diabetes Prevention Trial–Type 1 (DPT-1). Through longitudinal natural history studies, as well as trials before and after clinical onset of disease combined with mechanistic and ancillary investigations to enhance scientific understanding and translation to clinical use, TrialNet is working to bring disease-modifying therapies to individuals with type 1 diabetes. Moreover, TrialNet uses its expertise and experience in clinical studies to increase efficiencies in the conduct of trials and to reduce the burden of participation on individuals and families. Herein, we highlight key contributions made by TrialNet toward a revised understanding of the natural history of disease and approaches to alter disease course and outline the consortium’s plans for the future.},
	language = {en},
	number = {4},
	urldate = {2023-11-29},
	journal = {Diabetes Care},
	author = {Bingley, Polly J. and Wherrett, Diane K. and Shultz, Ann and Rafkin, Lisa E. and Atkinson, Mark A. and Greenbaum, Carla J.},
	month = apr,
	year = {2018},
	pages = {653--661},
	file = {Bingley et al. - 2018 - Type 1 Diabetes TrialNet A Multifaceted Approach .pdf:/Users/andrico/Documents/Zotero genetics/storage/88BHU3ZI/Bingley et al. - 2018 - Type 1 Diabetes TrialNet A Multifaceted Approach .pdf:application/pdf},
