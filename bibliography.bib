@article{yang_elf1_2011,
	title = {{ELF1} is associated with systemic lupus erythematosus in {Asian} populations},
	volume = {20},
	issn = {1460-2083},
	doi = {10.1093/hmg/ddq474},
	abstract = {Systemic lupus erythematosus (SLE) is an autoimmune disease with a strong genetic involvement. The susceptibility genes identified so far can only explain a small proportion of disease heritability. Through a genome-wide association in a Hong Kong Chinese cohort and subsequent replication in two other Asian populations, with a total of 3164 patients and 4482 matched controls, we identified association of ELF1 (E74-like factor 1) with SLE (rs7329174, OR = 1.26, joint P= 1.47 × 10(-8)). ELF1 belongs to the ETS family of transcription factors and is known to be involved in T cell development and function. Database analysis revealed transcripts making use of three alternative exon1s for this gene. Near equivalent expression levels of distinct transcripts initiated from alternative exon1s were detected in peripheral blood mononuclear cells from both SLE patients and healthy controls. Although a direct association of rs7329174 with the three forms of transcripts for this gene was not detected, these findings support an important role of ELF1 in SLE susceptibility and suggest a potentially tight regulation for the expression of this gene.},
	language = {eng},
	number = {3},
	journal = {Human Molecular Genetics},
	author = {Yang, Jing and Yang, Wanling and Hirankarn, Nattiya and Ye, Dong Qing and Zhang, Yan and Pan, Hai-Feng and Mok, Chi Chiu and Chan, Tak Mao and Wong, Raymond Woon Sing and Mok, Mo Yin and Lee, Ka Wing and Wong, Sik Nin and Leung, Alexander Moon Ho and Li, Xiang-Pei and Avihingsanon, Yingyos and Rianthavorn, Pornpimol and Deekajorndej, Thavatchai and Suphapeetiporn, Kanya and Shotelersuk, Vorasuk and Baum, Larry and Kwan, Patrick and Lee, Tsz Leung and Ho, Marco Hok Kung and Lee, Pamela Pui Wah and Wong, Wilfred Hing Sang and Zeng, Shuai and Zhang, Jing and Wong, Chun-Ming and Ng, Irene Oi Lin and Garcia-Barceló, Maria-Mercè and Cherny, Stacey S. and Tam, Paul Kwong-Hang and Sham, Pak Chung and Lau, Chak Sing and Lau, Yu Lung},
	month = feb,
	year = {2011},
	pmid = {21044949},
	keywords = {Humans, Genome-Wide Association Study, Asian People, Genetic Predisposition to Disease, Genotype, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, China, Transcription Factors, Haplotypes, Databases, Genetic, Thailand, Sequence Analysis, DNA, Ephrin-A2, Hong Kong, Polymerase Chain Reaction, T-Lymphocytes},
	pages = {601--607},
	file = {Full Text:/Users/andrico/Documents/Zotero genetics/storage/7RQ7CITM/Yang et al. - 2011 - ELF1 is associated with systemic lupus erythematosus in Asian populations.pdf:application/pdf},
}

@article{zhang_isgylation_2021,
	title = {{ISGylation} in {Innate} {Antiviral} {Immunity} and {Pathogen} {Defense} {Responses}: {A} {Review}},
	volume = {9},
	issn = {2296-634X},
	shorttitle = {{ISGylation} in {Innate} {Antiviral} {Immunity} and {Pathogen} {Defense} {Responses}},
	url = {https://www.frontiersin.org/articles/10.3389/fcell.2021.788410/full},
	doi = {10.3389/fcell.2021.788410},
	abstract = {The interferon-stimulating gene 15 (ISG15) protein is a ubiquitin-like protein induced by interferons or pathogens. ISG15 can exist in free form or covalently bind to the target protein through an enzymatic cascade reaction, which is called ISGylation. ISGylation has been found to play an important role in the innate immune responses induced by type I interferon, and is, thus, critical for the defense of host cells against RNA, DNA, and retroviruses. Through covalent binding with the host and viral target proteins, ISG15 inhibits the release of viral particles, hinder viral replication, and regulates the incubation period of viruses, thereby exerting strong antiviral effects. The SARS-CoV-2 papain-like protease, a virus-encoded deubiquitinating enzyme, has demonstrated activity on both ubiquitin and ISG15 chain conjugations, thus playing a suppressive role against the host antiviral innate immune response. Here we review the recent research progress in understanding ISG15-type ubiquitin-like modifications, with an emphasis on the underlying molecular mechanisms. We provide comprehensive references for further studies on the role of ISG15 in antiviral immunity, which may enable development of new antiviral drugs.},
	language = {en},
	urldate = {2025-05-12},
	journal = {Frontiers in Cell and Developmental Biology},
	author = {Zhang, Mengdi and Li, Jingxian and Yan, Haiyan and Huang, Jun and Wang, Fangwei and Liu, Ting and Zeng, Linghui and Zhou, Fangfang},
	month = nov,
	year = {2021},
	pages = {788410},
	file = {PDF:/Users/andrico/Documents/Zotero genetics/storage/GRVZ44U6/Zhang et al. - 2021 - ISGylation in Innate Antiviral Immunity and Pathogen Defense Responses A Review.pdf:application/pdf},
}

