	pages = {e73943},
	file = {Siwiak and Zielenkiewicz - 2013 - Transimulation - Protein Biosynthesis Web Service.pdf:/Users/lana/Zotero/storage/V2QVP8ET/Siwiak and Zielenkiewicz - 2013 - Transimulation - Protein Biosynthesis Web Service.pdf:application/pdf},
}

