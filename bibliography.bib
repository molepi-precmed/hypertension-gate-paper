	journal = {The FEBS Journal},
	author = {Moffitt, Jeffrey R. and Bustamante, Carlos},
	year = {2014},
	note = {\_eprint: https://febs.onlinelibrary.wiley.com/doi/pdf/10.1111/febs.12545},
	keywords = {continuous time Markov models, dwell time distribution, enzyme kinetics, phase-type distribution, queuing theory, randomness parameter, renewal theory, statistical kinetics},
	pages = {498--517},
	file = {Full Text PDF:/Users/lana/Zotero/storage/YC4GABD2/Moffitt and Bustamante - 2014 - Extracting signal from noise kinetic mechanisms f.pdf:application/pdf;Snapshot:/Users/lana/Zotero/storage/5RD7PF2E/febs.html:text/html},
}

