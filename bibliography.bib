	title = {Macromolecular {Crowding} and {Confinement}: {Biochemical}, {Biophysical}, and {Potential} {Physiological} {Consequences}},
	volume = {37},
	issn = {1936-122X, 1936-1238},
	shorttitle = {Macromolecular {Crowding} and {Confinement}},
