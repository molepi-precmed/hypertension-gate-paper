	keywords = {Drosophila melanogaster, Invertebrate genomics, Drosophila, Autosomes, Heterozygosity, Nucleotides, Sequence alignment, X chromosomes},
	pages = {e310},
	file = {Full Text PDF:/Users/lana/Zotero/storage/TYLPTUBY/Begun et al. - 2007 - Population Genomics Whole-Genome Analysis of Poly.pdf:application/pdf},
