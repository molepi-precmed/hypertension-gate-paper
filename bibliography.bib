	author = {Yu, Qin and Herrero Del Valle, Alba and Singh, Rahul and Modis, Yorgo},
	month = nov,
	year = {2021},
	pages = {6668},
	file = {Yu et al. - 2021 - MDA5 disease variant M854K prevents ATP-dependent .pdf:/Users/andrico/Documents/Zotero genetics/storage/XHFN95QZ/Yu et al. - 2021 - MDA5 disease variant M854K prevents ATP-dependent .pdf:application/pdf},
