	keywords = {Humans, Case-Control Studies, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, White People, Age of Onset, American Indian or Alaska Native, Black People, Genetic Load, Hispanic or Latino, HLA Antigens, Logistic Models, Multifactorial Inheritance, Mutagenesis, Insertional, Sequence Deletion},
