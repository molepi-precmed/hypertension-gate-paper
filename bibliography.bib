}

@article{gillespieChemicalLangevinEquation2000,
	title = {The chemical {Langevin} equation {Approximate} simulation of coupled fast and slow reactions for stochastic chemical kinetics {The} chemical {Langevin} equation},
	volume = {113},
	url = {https://doi.org/10.1063/1.481811},
	doi = {10.1063/1.2145882},
	abstract = {The stochastic dynamical behavior of a well-stirred mixture of N molecular species that chemically interact through M reaction channels is accurately described by the chemical master equation. It is shown here that, whenever two explicit dynamical conditions are satisfied, the microphysical premise from which the chemical master equation is derived leads directly to an approximate time-evolution equation of the Langevin type. This chemical Langevin equation is the same as one studied earlier by Kurtz, in contradistinction to some other earlier proposed forms that assume a deterministic macroscopic evolution law. The novel aspect of the present analysis is that it shows that the accuracy of the equation depends on the satisfaction of certain specific conditions that can change from moment to moment, rather than on a static system size parameter. The derivation affords a new perspective on the origin and magnitude of noise in a chemically reacting system. It also clarifies the connection between the stochastically correct chemical master equation, and the deterministic but often satisfactory reaction rate equation. ͓S0021-9606͑00͒50925-8͔},
	number = {10},
	journal = {The Journal of Chemical Physics The Journal of Chemical Physics The Journal of Chemical Physics The Journal of Chemical Physics The Journal of Chemical Physics The Journal of Chemical Physics The Journal of Chemical Physics},
	author = {Gillespie, Daniel T},
	year = {2000},
	pages = {170901--24103},
