	keywords = {Humans, Female, Genome-Wide Association Study, Male, Asian People, Case-Control Studies, Genetic Predisposition to Disease, Genotype, Lupus Erythematosus, Systemic, Genetic Loci, Adult, Asia, Eastern, Bayes Theorem, China, epidemiology, genetic, Genetic Variation, Japan, lupus erythematosus, Middle Aged, polymorphism, Prevalence, Republic of Korea, systemic},
