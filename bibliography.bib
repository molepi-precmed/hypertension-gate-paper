	month = sep,
	year = {2019},
	pages = {1616--1627},
	file = {on behalf of the FinnDiane Study Group and the Scottish Diabetes Research Network (SDRN) Type 1 Bioresource Collaboration et al. - 2019 - Biomarker panels associated with progression of re.pdf:/Users/andrico/Documents/Zotero genetics/storage/55ZBID8X/on behalf of the FinnDiane Study Group and the Scottish Diabetes Research Network (SDRN) Type 1 Bioresource Collaboration et al. - 2019 - Biomarker panels associated with progression of re.pdf:application/pdf},
