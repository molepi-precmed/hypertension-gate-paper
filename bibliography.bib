	pmcid = {PMC9897193},
	pages = {evad008},
	file = {PubMed Central Full Text PDF:/Users/lana/Zotero/storage/9IXAJNT6/Korfmann et al. - 2023 - Deep Learning in Population Genetics.pdf:application/pdf},
}

