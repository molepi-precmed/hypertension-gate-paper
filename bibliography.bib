	pmid = {24871463},
	pmcid = {PMC4156543},
	keywords = {Humans, Female, Genome-Wide Association Study, Genetic Predisposition to Disease, Genotype, Lupus Erythematosus, Systemic, Polymorphism, Single Nucleotide, HLA Antigens, Logistic Models, Gene Frequency, Haplotypes, Principal Component Analysis},
	pages = {347--354},
