@article{abdullahEndogenousAntigenspecificCD82025,
	title = {The endogenous antigen-specific {CD8}+ {T} cell repertoire is composed of unbiased and biased clonotypes with differential fate commitments},
	issn = {1074-7613},
	url = {https://www.sciencedirect.com/science/article/pii/S1074761325000688},
	doi = {10.1016/j.immuni.2025.02.001},
	abstract = {Generating balanced populations of CD8+ effector and memory T cells is necessary for immediate and durable immunity to infections and cancer. Yet, a definitive understanding of how a diverse CD8+ T cell repertoire differentiates remains unclear. We identified several hundred T cell receptor (TCR) clonotypes that constitute the polyclonal response against a single antigen and found that a majority of TCR clonotypes were highly biased toward memory or effector fates. TCR-intrinsic biases were not stochastic and were dominant over environmental cues. Differential gene expression analysis of memory- or effector-biased TCR clonotypes showed bifurcation of differential fates at the early effector stage. Additionally, phylogenetic analysis revealed that memory-biased clonotypes retain their fate preferences in subclonal populations but effector-biased subclones can switch to a memory fate. Our study highlights that the polyclonal CD8+ T cell response is a composite of unbiased and biased clonotypes with varying capacity to incorporate environmental cues in their cell fate decisions.},
	urldate = {2025-03-03},
	journal = {Immunity},
	author = {Abdullah, Leena and Emiliani, Francesco E. and Vaidya, Chinmay M. and Stuart, Hannah and Musial, Shawn C. and Kolling, Fred W. and Obar, Joshua J. and Rosato, Pamela C. and Ackerman, Margaret E. and Song, Li and McKenna, Aaron and Huang, Yina H.},
	month = feb,
	year = {2025},
	keywords = {endogenous CD8 T cell response, hierarchal lineage tracing, T cell fate bias},
	file = {ScienceDirect Snapshot:/Users/lana/Zotero/storage/FP2WWWCI/S1074761325000688.html:text/html},
