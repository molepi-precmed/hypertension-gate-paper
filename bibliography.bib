	month = sep,
	year = {2019},
	pages = {eaav7188},
	file = {International Multiple Sclerosis Genetics Consortium et al. - 2019 - Multiple sclerosis genomic map implicates peripher.pdf:/Users/andrico/Documents/Zotero genetics/storage/RM774L9T/International Multiple Sclerosis Genetics Consortium et al. - 2019 - Multiple sclerosis genomic map implicates peripher.pdf:application/pdf},
