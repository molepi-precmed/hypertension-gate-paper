@techreport{swafferRNAPolymeraseII2021,
	type = {preprint},
	title = {{RNA} polymerase {II} dynamics and {mRNA} stability feedback determine {mRNA} scaling with cell size},
	url = {http://biorxiv.org/lookup/doi/10.1101/2021.09.20.461005},
	abstract = {A defining feature of cellular growth is that protein and mRNA amounts scale with cell size so that concentrations remain approximately constant, thereby ensuring similar reaction rates and efficient biosynthesis. A key component of this biosynthetic scaling is the scaling of mRNA amounts with cell size, which occurs even among cells with the same DNA template copy number. Here, we identify RNA polymerase II as a major limiting factor increasing transcription with cell size. Other components of the transcriptional machinery are only minimally limiting and the chromatin environment is largely invariant with size. However, RNA polymerase II activity does not increase in direct proportion to cell size, inconsistent with previously proposed DNA-titration models. Instead, our data support a dynamic equilibrium model where the rate of polymerase loading is proportional to the unengaged nucleoplasmic polymerase concentration. This sublinear transcriptional increase is then balanced by a compensatory increase in mRNA stability as cells get larger. Taken together, our results show how limiting RNA polymerase II and feedback on mRNA stability work in concert to ensure the precise scaling of mRNA amounts across the physiological cell size range.},
	language = {en},
	urldate = {2021-09-28},
	institution = {Molecular Biology},
	author = {Swaffer, Matthew P. and Marinov, Georgi K. and Zheng, Huan and Jones, Andrew W. and Greenwood, Jessica and Kundaje, Anshul and Snijders, Ambrosius P. and Greenleaf, William J. and Reyes-Lamothe, Rodrigo and Skotheim, Jan M.},
	month = sep,
	year = {2021},
	doi = {10.1101/2021.09.20.461005},
	file = {Swaffer et al. - 2021 - RNA polymerase II dynamics and mRNA stability feed.pdf:/Users/lana/Zotero/storage/W3S6WLS9/Swaffer et al. - 2021 - RNA polymerase II dynamics and mRNA stability feed.pdf:application/pdf},
}

@article{swafferRNAPolymeraseII2021a,
	title = {{RNA} polymerase {II} dynamics and {mRNA} stability feedback determine {mRNA} scaling with cell size},
	url = {http://biorxiv.org/lookup/doi/10.1101/2021.09.20.461005},
	doi = {10.1101/2021.09.20.461005},
	abstract = {A defining feature of cellular growth is that protein and mRNA amounts scale with cell size so that concentrations remain approximately constant, thereby ensuring similar reaction rates and efficient biosynthesis. A key component of this biosynthetic scaling is the scaling of mRNA amounts with cell size, which occurs even among cells with the same DNA template copy number. Here, we identify RNA polymerase II as a major limiting factor increasing transcription with cell size. Other components of the transcriptional machinery are only minimally limiting and the chromatin environment is largely invariant with size. However, RNA polymerase II activity does not increase in direct proportion to cell size, inconsistent with previously proposed DNA-titration models. Instead, our data support a dynamic equilibrium model where the rate of polymerase loading is proportional to the unengaged nucleoplasmic polymerase concentration. This sublinear transcriptional increase is then balanced by a compensatory increase in mRNA stability as cells get larger. Taken together, our results show how limiting RNA polymerase II and feedback on mRNA stability work in concert to ensure the precise scaling of mRNA amounts across the physiological cell size range.},
	language = {en},
	urldate = {2021-09-23},
	author = {Swaffer, Matthew P. and Marinov, Georgi K. and Zheng, Huan and Jones, Andrew W. and Greenwood, Jessica and Kundaje, Anshul and Snijders, Ambrosius P. and Greenleaf, William J. and Reyes-Lamothe, Rodrigo and Skotheim, Jan M.},
	month = sep,
	year = {2021},
	file = {Swaffer et al. - 2021 - RNA polymerase II dynamics and mRNA stability feed.pdf:/Users/lana/Zotero/storage/QC3RH3PS/Swaffer et al. - 2021 - RNA polymerase II dynamics and mRNA stability feed.pdf:application/pdf},
}

@article{kempeVolumesTranscriptCounts2015,
	title = {The volumes and transcript counts of single cells reveal concentration homeostasis and capture biological noise},
	volume = {26},
	issn = {1059-1524, 1939-4586},
	url = {https://www.molbiolcell.org/doi/10.1091/mbc.E14-08-1296},
	doi = {10.1091/mbc.E14-08-1296},
	abstract = {Transcriptional stochasticity can be measured by counting the number of mRNA molecules per cell. Cell-to-cell variability is best captured in terms of concentration rather than molecule counts, because reaction rates depend on concentrations. We combined single-molecule mRNA counting with single-cell volume measurements to quantify the statistics of both transcript numbers and concentrations in human cells. We compared three cell clones that differ only in the genomic integration site of an identical constitutively expressed reporter gene. The transcript number per cell varied proportionally with cell volume in all three clones, indicating concentration homeostasis. We found that the cell-to-cell variability in the mRNA concentration is almost exclusively due to cell-to-cell variation in gene expression activity, whereas the cell-to-cell variation in mRNA number is larger, due to a significant contribution of cell volume variability. We concluded that the precise relationship between transcript number and cell volume sets the biological stochasticity of living cells. This study highlights the importance of the quantitative measurement of transcript concentrations in studies of cell-to-cell variability in biology.},
	language = {en},
	number = {4},
	urldate = {2021-09-09},
	journal = {Molecular Biology of the Cell},
	author = {Kempe, Hermannus and Schwabe, Anne and Crémazy, Frédéric and Verschure, Pernette J. and Bruggeman, Frank J.},
	editor = {Matera, A. Gregory},
	month = feb,
	year = {2015},
	pages = {797--804},
	file = {Kempe et al. - 2015 - The volumes and transcript counts of single cells .pdf:/Users/lana/Zotero/storage/HLKBSDMV/Kempe et al. - 2015 - The volumes and transcript counts of single cells .pdf:application/pdf},
}

